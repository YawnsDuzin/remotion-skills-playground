{
  "name": "example-daily-report",
  "version": "0.1.0",
  "private": true,
  "description": "Daily KOSPI/USD/Weather report video — calculateMetadata + caching + chart",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render src/index.ts DailyReport \"out/$(date +%Y-%m-%d).mp4\"",
    "build:mock": "USE_MOCK=true remotion render src/index.ts DailyReport out/mock.mp4",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
