{
  "name": "example-title-card",
  "version": "0.1.0",
  "private": true,
  "description": "Simplest possible Remotion example: 5-second title card",
  "scripts": {
    "start": "remotion studio",
    "build:landscape": "remotion render src/index.ts TitleCardLandscape out/title-landscape.mp4",
    "build:portrait": "remotion render src/index.ts TitleCardPortrait out/title-portrait.mp4",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
