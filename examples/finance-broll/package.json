{
  "name": "example-finance-broll",
  "version": "0.1.0",
  "private": true,
  "description": "Finance video with Veo/Pexels B-roll inserts between data scenes — hybrid pattern",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render src/index.ts FinanceBroll out/finance-broll.mp4",
    "build:mock": "USE_MOCK_BROLL=true remotion render src/index.ts FinanceBroll out/finance-broll-mock.mp4",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/transitions": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^6.0.3"
  }
}
